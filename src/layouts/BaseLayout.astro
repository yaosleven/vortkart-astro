---
import '../styles/global.css';
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  canonical?: string;
}

const {
  title,
  description = 'VortKart® is a leading commercial go kart manufacturer offering rental go karts, racing chassis production, and complete go kart track design & turnkey solutions worldwide.',
  keywords = 'commercial go kart, rental go kart, go kart manufacturer, go kart supplier, go kart track design, karting solutions',
  ogTitle,
  ogDescription,
  ogImage = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1200&q=80',
  canonical,
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  {canonical && <link rel="canonical" href={canonical} />}
  <meta property="og:title" content={ogTitle || title} />
  <meta property="og:description" content={ogDescription || description} />
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:site_name" content="VortKart®" />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle || title} />
  <meta name="twitter:description" content={ogDescription || description} />
  <meta name="robots" content="index, follow" />
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "VortKart International",
    "url": "https://vortkart.com/",
    "description": "Leading manufacturer of commercial go karts, racing chassis, and turnkey karting solutions.",
    "telephone": "+1-234-567-890",
    "email": "sales@vortkart.com"
  }
  </script>
</head>
<body>

<!-- ======================== NAVBAR ======================== -->
<nav id="navbar">
  <div class="container">
    <div class="nav-inner">
      <a href={`${base}/`} class="nav-logo" aria-label="VortKart Home">
        <div class="nav-logo-icon">VK</div>
        <div class="nav-logo-text">Vort<span>Kart</span><sup style="font-size:10px;vertical-align:super;">®</sup></div>
      </a>
      <ul class="nav-links" role="navigation" aria-label="Main navigation">
        <li><a href={`${base}/`}>Home</a></li>
        <li><a href={`${base}/about`}>About</a></li>
        <li><a href={`${base}/services`}>Services</a></li>
        <li><a href={`${base}/listings`}>Portfolio</a></li>
        <li><a href={`${base}/contact`}>Contact</a></li>
      </ul>
      <div class="nav-cta">
        <a href="tel:+1234567890" class="nav-phone" aria-label="Call us">+1 (234) 567-890</a>
        <a href={`${base}/contact`} class="btn btn-primary">Get a Quote</a>
      </div>
      <button class="nav-toggle" id="navToggle" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Nav -->
<div class="mobile-nav" id="mobileNav" role="navigation" aria-label="Mobile navigation">
  <a href={`${base}/`}>Home</a>
  <a href={`${base}/about`}>About</a>
  <a href={`${base}/services`}>Services</a>
  <a href={`${base}/listings`}>Portfolio</a>
  <a href={`${base}/contact`}>Contact</a>
  <a href={`${base}/contact`} class="btn btn-primary">Get a Free Quote</a>
</div>

<!-- ======================== PAGE CONTENT ======================== -->
<slot />

<!-- ======================== FOOTER ======================== -->
<footer>
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <a href={`${base}/`} class="nav-logo" aria-label="VortKart Home">
          <div class="nav-logo-icon">VK</div>
          <div class="nav-logo-text">Vort<span>Kart</span><sup style="font-size:10px;vertical-align:super;">®</sup></div>
        </a>
        <p>The world's leading manufacturer of commercial go karts and provider of complete karting attraction solutions. Factory direct. Globally trusted.</p>
        <div class="footer-social" aria-label="Social media links">
          <a href="#" class="social-icon" aria-label="Facebook"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></a>
          <a href="#" class="social-icon" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg></a>
          <a href="#" class="social-icon" aria-label="LinkedIn"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg></a>
          <a href="#" class="social-icon" aria-label="YouTube"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-1.95C18.88 4 12 4 12 4s-6.88 0-8.6.47a2.78 2.78 0 00-1.94 1.95A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.4 19.53C5.12 20 12 20 12 20s6.88 0 8.6-.47a2.78 2.78 0 001.94-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#0a0a0a"/></svg></a>
        </div>
      </div>
      <div class="footer-col">
        <h5>Quick Links</h5>
        <a href={`${base}/`}>Home</a>
        <a href={`${base}/about`}>About Us</a>
        <a href={`${base}/services`}>Services</a>
        <a href={`${base}/listings`}>Portfolio</a>
        <a href={`${base}/contact`}>Contact</a>
      </div>
      <div class="footer-col">
        <h5>Services</h5>
        <a href={`${base}/services#commercial`}>Commercial Go Karts</a>
        <a href={`${base}/services#racing`}>Racing Chassis</a>
        <a href={`${base}/services#track`}>Track Design</a>
        <a href={`${base}/services#turnkey`}>Turnkey Solutions</a>
        <a href={`${base}/contact`}>Parts &amp; Support</a>
      </div>
      <div class="footer-col">
        <h5>Contact</h5>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 010 2.94 2 2 0 012 .76h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          <span>+1 (234) 567-890</span>
        </div>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>sales@vortkart.com</span>
        </div>
        <div class="footer-contact-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>123 Motorsport Drive,<br />Karting District, CA 90001</span>
        </div>
      </div>
    </div>
  </div>
  <div class="divider"></div>
  <div class="container">
    <div class="footer-bottom">
      <p>&copy; 2026 VortKart® International. All rights reserved.</p>
      <div class="footer-bottom-links">
        <a href={`${base}/privacy`}>Privacy Policy</a>
        <a href={`${base}/terms`}>Terms of Service</a>
        <a href={`${base}/sitemap.xml`}>Sitemap</a>
      </div>
    </div>
  </div>
</footer>

<script src={`${base}/main.js`}></script>
</body>
</html>
