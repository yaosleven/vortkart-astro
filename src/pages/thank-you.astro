---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CONTACT } from '../config/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="Thank You | VortKart® — We've Received Your Message"
  description="Thank you for contacting VortKart®. Our team will review your enquiry and respond within 24 hours."
  canonical="https://vortkart.com/thank-you"
>
<style>
  .thank-you {
    min-height: calc(100vh - var(--nav-height));
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--dark);
    position: relative;
    overflow: hidden;
    padding: 60px 24px;
  }

  .thank-you::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(249,115,22,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(249,115,22,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  .ty-inner {
    text-align: center;
    max-width: 580px;
    position: relative;
    z-index: 1;
  }

  .ty-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(34,197,94,0.1);
    border: 2px solid rgba(34,197,94,0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 32px;
    animation: ty-pop .6s cubic-bezier(.34,1.56,.64,1) both;
  }
  .ty-icon svg {
    width: 36px;
    height: 36px;
    color: #22c55e;
  }

  @keyframes ty-pop {
    0% { transform: scale(0); opacity: 0; }
    100% { transform: scale(1); opacity: 1; }
  }

  .ty-title {
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .ty-desc {
    font-size: 16px;
    color: var(--gray-3);
    line-height: 1.7;
    margin-bottom: 12px;
  }

  .ty-promise {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--primary);
    margin-bottom: 40px;
  }
  .ty-promise svg {
    width: 18px;
    height: 18px;
  }

  .ty-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }
  .ty-actions .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: var(--transition);
  }
  .ty-actions .btn svg { width: 16px; height: 16px; }

  .ty-contact {
    padding-top: 40px;
    border-top: 1px solid rgba(255,255,255,0.06);
  }
  .ty-contact p {
    font-size: 13px;
    color: var(--gray-2);
    margin-bottom: 16px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .ty-contact-methods {
    display: flex;
    gap: 24px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .ty-contact-methods a {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--gray-4);
    transition: var(--transition);
  }
  .ty-contact-methods a:hover { color: var(--primary); }
  .ty-contact-methods svg { width: 16px; height: 16px; }

  @media (max-width: 640px) {
    .ty-actions { flex-direction: column; align-items: center; }
    .ty-actions .btn { width: 100%; max-width: 260px; justify-content: center; }
    .ty-contact-methods { flex-direction: column; align-items: center; gap: 12px; }
  }
</style>

<section class="thank-you">
  <div class="ty-inner">
    <div class="ty-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </div>

    <h1 class="ty-title">Message <span class="highlight">Received!</span></h1>
    <p class="ty-desc">Thank you for reaching out to VortKart®. Our team has received your enquiry and will review it shortly.</p>
    <div class="ty-promise">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      We guarantee a response within 24 hours.
    </div>

    <div class="ty-actions">
      <a href={`${base}/`} class="btn btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        Back to Home
      </a>
      <a href={`${base}/portfolio`} class="btn btn-outline">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Browse Products
      </a>
    </div>

    <div class="ty-contact">
      <p>Need Immediate Assistance?</p>
      <div class="ty-contact-methods">
        <a href={`tel:${CONTACT.phoneRaw}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 010 2.94 2 2 0 012 .76h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          {CONTACT.phone}
        </a>
        <a href={`mailto:${CONTACT.email}`}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {CONTACT.email}
        </a>
        <a href={`https://wa.me/${CONTACT.whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ===== Google Ads Quote conversion + GA4 lead event (fires on this success page) ===== -->
<script is:inline set:html={`
  (function () {
    if (typeof window.gtag !== 'function') return;
    // GA4 lead event
    window.gtag('event', 'generate_lead', { event_category: 'quote', event_label: 'Quote Form' });
    // Google Ads conversion — only if both Ads ID and conversion label are configured
    if (window.VK_ADS_ID && window.VK_QUOTE_LABEL) {
      window.gtag('event', 'conversion', { send_to: window.VK_ADS_ID + '/' + window.VK_QUOTE_LABEL });
    }
  })();
`} />
</BaseLayout>
