---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="SpeedZone Family Park — Turnkey Project | VortKart®"
  description="How VortKart® designed and delivered a complete 800m outdoor karting attraction for SpeedZone Family Park in under 6 months."
  canonical="https://vortkart.com/project"
>
<style>
.project-hero{position:relative;min-height:560px;display:flex;align-items:flex-end;overflow:hidden;padding-top:var(--nav-height)}
.project-hero-bg{position:absolute;inset:0;background-size:cover;background-position:center}
.project-hero-overlay{position:absolute;inset:0;background:linear-gradient(135deg,rgba(10,10,10,0.97) 0%,rgba(10,10,10,0.82) 60%,rgba(10,10,10,0.65) 100%)}
.project-hero-content{position:relative;z-index:2;padding:60px 0}
.pr-title{font-size:clamp(32px,5vw,60px);margin-bottom:12px}
.pr-subtitle{font-size:18px;color:var(--gray-4);max-width:560px;margin-bottom:24px}
.pr-hero-stats{display:flex;gap:40px;flex-wrap:wrap;padding-top:24px;border-top:1px solid rgba(255,255,255,0.12)}
.pr-hero-stat .num{font-family:var(--font-heading);font-size:30px;font-weight:800;color:var(--primary);line-height:1}
.pr-hero-stat .lbl{font-size:11px;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:.1em;margin-top:2px}
.pr-overview-grid{display:grid;grid-template-columns:1fr 360px;gap:64px;align-items:start}
.pr-facts-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-xl);padding:32px;position:sticky;top:calc(var(--nav-height) + 24px)}
.pr-fact{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.06)}
.pr-fact:last-child{border-bottom:none}
.pr-fact-label{font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--gray-3)}
.pr-fact-value{font-size:14px;font-weight:700;color:var(--white);text-align:right}
.pr-gallery{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
.pr-gallery-img{border-radius:var(--radius-lg);overflow:hidden;aspect-ratio:4/3}
.pr-gallery-img img{width:100%;height:100%;object-fit:cover;transition:transform .4s ease}
.pr-gallery-img:hover img{transform:scale(1.04)}
.pr-testimonial{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-xl);padding:48px;position:relative;margin-top:64px}
.pr-testimonial::before{content:'\201C';font-family:var(--font-heading);font-size:120px;color:var(--primary);opacity:.15;position:absolute;top:-20px;left:32px;line-height:1}
.pr-testimonial-text{font-size:20px;font-style:italic;color:var(--white);line-height:1.65;margin-bottom:24px;position:relative;z-index:1}
.pr-scope-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.pr-scope-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.07);border-radius:var(--radius-lg);padding:28px;transition:var(--transition)}
.pr-scope-card:hover{border-color:rgba(230,57,0,0.3);transform:translateY(-4px)}
.pr-scope-icon{width:44px;height:44px;background:rgba(230,57,0,0.1);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:16px}
.pr-scope-icon svg{width:22px;height:22px;color:var(--primary)}
.pr-scope-card h4{font-size:17px;margin-bottom:8px}
.pr-scope-card p{font-size:14px;color:var(--gray-3)}
.pr-fleet-table-wrap{border-radius:var(--radius-lg);overflow:hidden;border:1px solid rgba(255,255,255,0.07)}
.pr-fleet-table{width:100%;border-collapse:collapse}
.pr-fleet-table th,.pr-fleet-table td{padding:14px 20px;text-align:left;border-bottom:1px solid rgba(255,255,255,0.06);font-size:14px}
.pr-fleet-table th{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--primary);background:var(--dark-3)}
.pr-fleet-table td:first-child{color:var(--gray-4)}
.pr-fleet-table td:last-child{color:var(--primary);font-weight:600}
.pr-timeline{position:relative;padding-left:32px}
.pr-timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--primary),rgba(230,57,0,0.1))}
.pr-timeline-item{position:relative;padding:0 0 44px 40px}
.pr-timeline-dot{position:absolute;left:-39px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--primary);border:3px solid var(--dark);box-shadow:0 0 0 3px rgba(230,57,0,0.3)}
.pr-timeline-date{font-family:var(--font-heading);font-size:13px;font-weight:800;color:var(--primary);letter-spacing:.1em;margin-bottom:6px}
.pr-timeline-item h4{font-size:19px;margin-bottom:6px}
.pr-timeline-item p{font-size:14px;color:var(--gray-3);max-width:560px}
.pr-related-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.06);border-radius:var(--radius-lg);overflow:hidden;transition:var(--transition);display:block;text-decoration:none}
.pr-related-card:hover{border-color:rgba(230,57,0,0.25);transform:translateY(-4px)}
.pr-related-card img{width:100%;aspect-ratio:16/9;object-fit:cover}
.pr-related-body{padding:22px}
.pr-related-body h4{font-size:18px;margin-bottom:6px}
.pr-related-body p{font-size:13px;color:var(--gray-3);margin-bottom:14px}
.pr-cta-bar{background:var(--dark-2);border-top:1px solid rgba(255,255,255,0.08);padding:60px 0;text-align:center}
.pr-cta-buttons{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:24px}
@media(max-width:1024px){.pr-overview-grid{grid-template-columns:1fr!important;gap:40px}.pr-facts-card{position:static!important}.pr-gallery{grid-template-columns:1fr 1fr!important}}
</style>

<section class="project-hero">
  <div class="project-hero-bg" style={`background-image:url('${base}/images/duratrak-270/2.jpg')`}></div>
  <div class="project-hero-overlay"></div>
  <div class="container"><div class="project-hero-content">
    <nav class="breadcrumb" style="margin-bottom:16px"><a href={`${base}/`}>Home</a><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg><a href={`${base}/listings`}>Portfolio</a><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg><span>SpeedZone</span></nav>
    <div class="label">Turnkey Project Case Study</div>
    <h1 class="pr-title">SpeedZone <span class="highlight">Family Park</span></h1>
    <p class="pr-subtitle">Complete 800m outdoor karting attraction — from site survey to grand opening in under 6 months.</p>
    <div class="pr-hero-stats">
      <div class="pr-hero-stat"><div class="num">850m</div><div class="lbl">Track Length</div></div>
      <div class="pr-hero-stat"><div class="num">40</div><div class="lbl">EV Karts</div></div>
      <div class="pr-hero-stat"><div class="num">5mo</div><div class="lbl">Timeline</div></div>
      <div class="pr-hero-stat"><div class="num">$3.2M</div><div class="lbl">Project Value</div></div>
    </div>
  </div></div>
</section>

<section class="section" style="background:var(--dark)">
  <div class="container"><div class="pr-overview-grid">
    <div class="pr-overview-text fade-in">
      <div class="label">Project Overview</div>
      <h2>From Empty Land to <span class="highlight">Opening Day</span></h2>
      <p style="margin-top:20px;margin-bottom:16px">SpeedZone Family Park approached VortKart® with a greenfield site and a vision for a world-class karting attraction. Starting with nothing but a flat plot of land, our team delivered a complete operational facility — track, karts, barriers, timing, signage, and staff training — in under 6 months.</p>
      <p>The 800-meter circuit was designed to accommodate 30 EV-Pro® 48V electric karts simultaneously, with a layout that maximized both track time per session and the spectator experience for non-riders. The result was an attraction that exceeded revenue projections in its first year of operation.</p>
      <div class="pr-gallery">
        <div class="pr-gallery-img"><img src={`${base}/images/ev-pro-48/3.jpg`} alt="SpeedZone track construction" loading="lazy" /></div>
        <div class="pr-gallery-img"><img src={`${base}/images/ev-pro-48/1.jpg`} alt="EV-Pro kart fleet" loading="lazy" /></div>
        <div class="pr-gallery-img"><img src={`${base}/images/kids-racing/4.jpg`} alt="SpeedZone opening day" loading="lazy" /></div>
      </div>
      <div class="pr-testimonial fade-in">
        <p class="pr-testimonial-text">"VortKart® designed our entire 800m track from scratch, supplied 30 electric karts, and had us operational in under 6 months. The ROI exceeded our projections in year one. We couldn't have asked for a better partner."</p>
        <div class="testimonial-author">
          <div class="author-avatar">JM</div>
          <div><div class="author-name">James Mitchell</div><div class="author-title">Owner, SpeedZone Family Park, USA</div></div>
        </div>
      </div>
    </div>
    <div class="fade-in delay-2">
      <div class="pr-facts-card">
        <h4 style="margin-bottom:24px;font-size:20px">Project <span class="highlight">Facts</span></h4>
        <div class="pr-fact"><span class="pr-fact-label">Client</span><span class="pr-fact-value">SpeedZone Family Park</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Location</span><span class="pr-fact-value">California, USA</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Project Type</span><span class="pr-fact-value">Turnkey Attraction</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Kart Model</span><span class="pr-fact-value">EV-Pro® 48V</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Fleet Size</span><span class="pr-fact-value">30 Units</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Track Length</span><span class="pr-fact-value">800 Metres</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Track Type</span><span class="pr-fact-value">Outdoor Asphalt</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Delivery Time</span><span class="pr-fact-value">&lt; 6 Months</span></div>
        <div class="pr-fact"><span class="pr-fact-label">Completed</span><span class="pr-fact-value">March 2024</span></div>
        <a href={`${base}/contact`} class="btn btn-primary" style="width:100%;justify-content:center;margin-top:28px">Start Similar Project</a>
      </div>
    </div>
  </div></div>
</section>

<section class="section" style="background:var(--dark-2)">
  <div class="container">
    <div class="section-header fade-in"><div class="label">Scope of Work</div><h2>What We <span class="highlight">Delivered</span></h2></div>
    <div class="pr-scope-grid fade-in delay-1">
      <div class="pr-scope-card"><div class="pr-scope-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg></div><h4>Track Design &amp; Construction</h4><p>850m FIA-spec circuit with 12 corners, elevation changes, drainage, and asphalt paving to motorsport-grade tolerances.</p></div>
      <div class="pr-scope-card"><div class="pr-scope-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3m-4 10v-6a2 2 0 012-2h6a2 2 0 012 2v6a2 2 0 01-2 2h-6a2 2 0 01-2-2z"/></svg></div><h4>Fleet Manufacturing &amp; Delivery</h4><p>40 custom-liveried EV-Pro® 48 electric karts manufactured, tested, and delivered with full spare parts package.</p></div>
      <div class="pr-scope-card"><div class="pr-scope-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18M3 3v14a2 2 0 002 2h14a2 2 0 002-2V3"/></svg></div><h4>Timing &amp; Scoring System</h4><p>Professional AMB timing system with digital leaderboard, driver performance printouts, and cloud-based session management.</p></div>
      <div class="pr-scope-card"><div class="pr-scope-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg></div><h4>Facility Infrastructure</h4><p>Pit lane, grid area, spectator grandstand (200 seats), driver briefing room, and maintenance workshop construction.</p></div>
      <div class="pr-scope-card"><div class="pr-scope-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg></div><h4>Staff Training &amp; Certification</h4><p>2-week on-site training for 12 staff covering operations, safety, kart maintenance, and emergency procedures.</p></div>
      <div class="pr-scope-card"><div class="pr-scope-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"/></svg></div><h4>Post-Launch Support</h4><p>12-month on-call technical support, quarterly maintenance visits, and remote fleet monitoring via VortKart Connect™.</p></div>
    </div>
  </div>
</section>

<section class="section" style="background:var(--dark)">
  <div class="container">
    <div class="section-header fade-in"><div class="label">Fleet Deployment</div><h2>Karts &amp; Equipment</h2></div>
    <div class="pr-fleet-table-wrap fade-in delay-1">
      <table class="pr-fleet-table">
        <thead><tr><th>Item</th><th>Quantity</th><th>Notes</th></tr></thead>
        <tbody>
          <tr><td>EV-Pro® 48 Electric Kart</td><td>40 units</td><td>Primary rental fleet</td></tr>
          <tr><td>JuniorSprint® EV</td><td>8 units</td><td>Junior track (Phase 2)</td></tr>
          <tr><td>AMB Timing Transponders</td><td>48 units</td><td>Kart-mounted</td></tr>
          <tr><td>Fast Charge Stations</td><td>6 units</td><td>45-min DC fast charge</td></tr>
          <tr><td>Spare Parts Package</td><td>1 set</td><td>2-year maintenance stock</td></tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="section" style="background:var(--dark-2)">
  <div class="container">
    <div class="section-header fade-in"><div class="label">Project Timeline</div><h2>From Concept to <span class="highlight">Completion</span></h2></div>
    <div class="pr-timeline fade-in delay-1" style="max-width:720px">
      <div class="pr-timeline-item"><div class="pr-timeline-dot"></div><div class="pr-timeline-date">Month 1</div><h4>Site Survey &amp; Design</h4><p>Geotechnical survey, track layout design, permits, and civil engineering plans finalized.</p></div>
      <div class="pr-timeline-item"><div class="pr-timeline-dot"></div><div class="pr-timeline-date">Month 2</div><h4>Groundbreaking &amp; Earthworks</h4><p>Site clearing, grading, drainage installation, and track bed preparation completed.</p></div>
      <div class="pr-timeline-item"><div class="pr-timeline-dot"></div><div class="pr-timeline-date">Month 3</div><h4>Track Paving &amp; Infrastructure</h4><p>Asphalt paving, barrier installation, pit lane construction, and facility build-out.</p></div>
      <div class="pr-timeline-item"><div class="pr-timeline-dot"></div><div class="pr-timeline-date">Month 4</div><h4>Fleet Delivery &amp; System Install</h4><p>40 EV-Pro karts delivered, timing system installed, charging stations commissioned.</p></div>
      <div class="pr-timeline-item"><div class="pr-timeline-dot"></div><div class="pr-timeline-date">Month 5</div><h4>Training, Testing &amp; Launch</h4><p>Staff training, safety certification, soft-opening test events, and public grand opening.</p></div>
    </div>
  </div>
</section>

<section class="section" style="background:var(--dark);padding-bottom:120px">
  <div class="container">
    <div class="section-header fade-in"><div class="label">More Work</div><h2>Related <span class="highlight">Projects</span></h2></div>
    <div class="grid-3 fade-in delay-1">
      <a href={`${base}/project`} class="pr-related-card"><img src={`${base}/images/ev-pro-48/3.jpg`} alt="Dubai Indoor Karting Dome" loading="lazy" /><div class="pr-related-body"><h4>Dubai Indoor Karting Dome</h4><p>600m indoor circuit, 30 EV-Max® karts, multi-level spectator gallery. UAE.</p><span style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--primary)">View Project →</span></div></a>
      <a href={`${base}/project`} class="pr-related-card"><img src={`${base}/images/duratrak-160/4.jpg`} alt="SunPark Karting Gold Coast" loading="lazy" /><div class="pr-related-body"><h4>SunPark Karting Experience</h4><p>35-kart gas fleet for high-volume theme park. 700m track. Gold Coast, Australia.</p><span style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--primary)">View Project →</span></div></a>
      <a href={`${base}/project`} class="pr-related-card"><img src={`${base}/images/duratrak-270/8.jpg`} alt="Grand Marina Resort Spain" loading="lazy" /><div class="pr-related-body"><h4>Grand Marina Resort Karting</h4><p>20 EV karts integrated into 5-star resort. Custom livery &amp; service contract. Spain.</p><span style="font-size:12px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--primary)">View Project →</span></div></a>
    </div>
  </div>
</section>

<div class="pr-cta-bar">
  <div class="container">
    <div class="label" style="justify-content:center">Your Turn</div>
    <h3 style="font-size:clamp(24px,4vw,44px)">Ready to Build Your<br><span class="highlight">Karting Attraction?</span></h3>
    <div class="pr-cta-buttons">
      <a href={`${base}/contact`} class="btn btn-primary btn-lg">Get a Free Quote</a>
      <a href={`${base}/listings`} class="btn btn-outline btn-lg">View More Projects</a>
    </div>
  </div>
</div>
</BaseLayout>
