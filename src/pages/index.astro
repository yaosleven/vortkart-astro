---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const websiteSchema = {
  "@type": "WebSite",
  "name": "VortKart",
  "url": "https://vortkart.com",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://vortkart.com/portfolio?q={search_term_string}",
    "query-input": "required name=search_term_string",
  },
};

const homepageFaqSchema = {
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What does VortKart® manufacture?", "acceptedAnswer": { "@type": "Answer", "text": "VortKart® manufactures commercial electric and gas-powered rental go karts, competition-grade racing chassis, and provides complete turnkey karting solutions — including track layout, installation support, and operator training." } },
    { "@type": "Question", "name": "How do I place an order?", "acceptedAnswer": { "@type": "Answer", "text": "Contact us via the website form, email, or WhatsApp with your venue type, expected throughput, and fleet preferences. We provide a detailed project quotation within 48 hours, along with lead times and payment terms (T/T or L/C). Standard fleet orders start from 5 units, with flexible options for smaller pilot orders." } },
    { "@type": "Question", "name": "What does a turnkey solution include?", "acceptedAnswer": { "@type": "Answer", "text": "Our turnkey service covers site assessment, track layout design, kart fleet supply, safety equipment guidance, remote or on-site installation support, operator training, and ongoing spare parts delivery to 60+ countries." } },
    { "@type": "Question", "name": "How do I choose between electric and gas karts?", "acceptedAnswer": { "@type": "Answer", "text": "Electric go karts offer zero emissions and quiet operation, ideal for indoor venues. Gas-powered go karts use reliable Honda GX engines built for outdoor tracks, with speed settings configurable based on track layout and safety requirements." } }
  ]
};
---
<BaseLayout
  title="VortKart® | Commercial Go Kart Manufacturer & Track Design Solutions"
  description="VortKart® is a factory-direct commercial go kart manufacturer offering rental go karts, racing chassis, and complete turnkey karting solutions for FECs, resorts, and track operators worldwide."
  keywords="go kart manufacturer, commercial go kart manufacturer, go kart supplier, go kart track design, turnkey karting solutions, go kart company, karting business solutions, go kart factory, commercial karting equipment, go kart wholesale"
  canonical="https://vortkart.com/"
  jsonLd={[websiteSchema, homepageFaqSchema]}
>
<style>
.hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;padding-top:var(--nav-height)}
.hero .container{position:relative;z-index:2;width:100%;max-width:1180px}
.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;background-repeat:no-repeat}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(102deg,rgba(6,8,13,0.88) 0%,rgba(6,8,13,0.68) 42%,rgba(6,8,13,0.28) 78%,rgba(6,8,13,0.18) 100%)}
.hero-content{position:relative;z-index:2;max-width:610px;padding:clamp(78px,13vh,118px) 0 82px;margin-left:0}
.hero-badge{display:inline-flex;align-items:center;gap:10px;background:rgba(6,8,13,0.38);border:1px solid rgba(249,115,22,0.42);border-radius:100px;padding:6px 15px 6px 6px;font-size:11px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--primary);margin-bottom:22px;backdrop-filter:blur(10px)}
.hero-badge span{background:var(--primary);color:var(--white);border-radius:100px;padding:3px 10px;font-size:11px}
.hero h1{margin-bottom:18px;font-size:clamp(42px,4.8vw,64px);line-height:1.02;letter-spacing:0;font-weight:800;max-width:540px}
.hero h1 em{font-style:normal;color:var(--primary)}
.hero-sub{font-size:17px;color:rgba(255,255,255,0.76);max-width:535px;margin-bottom:28px;line-height:1.62}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap;align-items:center;margin-bottom:34px}
.hero-actions .btn{min-height:54px;padding:15px 30px;border-radius:var(--radius-sm);letter-spacing:.07em}
.hero-actions .btn-outline{background:rgba(6,8,13,.18);border-color:rgba(255,255,255,.26);backdrop-filter:blur(8px)}
.hero-meta{display:flex;align-items:flex-start;gap:0;width:max-content;max-width:100%;padding-top:22px;border-top:1px solid rgba(255,255,255,0.12)}
.hero-meta-item{padding:0 30px;position:relative}
.hero-meta-item:first-child{padding-left:0}
.hero-meta-item:not(:first-child)::before{content:'';position:absolute;left:0;top:2px;bottom:2px;width:1px;background:rgba(255,255,255,0.14)}
.hero-meta-num{font-family:var(--font-heading);font-size:34px;font-weight:800;color:var(--white);line-height:1}
.hero-meta-num span{color:var(--primary)}
.hero-meta-label{font-size:10.5px;color:rgba(255,255,255,0.52);margin-top:6px;text-transform:uppercase;letter-spacing:.12em}
.scroll-indicator{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;z-index:2;opacity:.6}
.scroll-dot{width:20px;height:32px;border:1.5px solid rgba(255,255,255,0.15);border-radius:var(--radius-md);display:flex;justify-content:center;padding-top:6px}
.scroll-dot::before{content:'';width:3px;height:6px;background:var(--primary);border-radius:2px;animation:scrollDown 2s ease-in-out infinite}
@keyframes scrollDown{0%{transform:translateY(0);opacity:1}100%{transform:translateY(12px);opacity:0}}
.advantage-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-lg);padding:36px;transition:var(--transition);position:relative;overflow:hidden}
.advantage-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:var(--primary);transform:scaleX(0);transition:transform var(--transition);transform-origin:left}
.advantage-card:hover{border-color:rgba(249,115,22,0.3);transform:translateY(-6px)}
.advantage-card:hover::before{transform:scaleX(1)}
.advantage-icon{width:56px;height:56px;background:rgba(249,115,22,0.1);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:24px}
.advantage-icon svg{width:28px;height:28px;color:var(--primary)}
.advantage-card h3{min-height:2.6em;display:flex;align-items:flex-end;margin-bottom:14px}
.advantage-card>p{color:var(--gray-3);line-height:1.7}
.services-preview{background:var(--dark-2)}
.service-preview-card{position:relative;border-radius:var(--radius-lg);overflow:hidden;aspect-ratio:4/3;display:block;text-decoration:none}
.service-preview-card img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.service-preview-card:hover img{transform:scale(1.06)}
.service-preview-overlay{position:absolute;inset:0;background:linear-gradient(0deg,rgba(6,8,13,0.92) 0%,rgba(6,8,13,0.3) 60%,transparent 100%)}
.service-preview-content{position:absolute;bottom:0;left:0;right:0;padding:28px}
.service-tag{display:inline-block;background:var(--primary);color:var(--white);font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;border-radius:var(--radius-sm);margin-bottom:8px}
.service-preview-content h4{font-size:22px;color:var(--white);margin-bottom:6px}
.service-preview-content p{font-size:13px;color:rgba(255,255,255,0.7)}
.service-arrow{position:absolute;top:24px;right:24px;width:40px;height:40px;border-radius:50%;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;opacity:0;transform:translate(8px,-8px);transition:var(--transition)}
.service-preview-card:hover .service-arrow{opacity:1;transform:translate(0,0)}
.service-arrow svg{width:16px;height:16px}
.about-preview{background:var(--dark)}
.about-preview-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.about-img-stack{position:relative;overflow:visible}
.about-img-main{border-radius:var(--radius-xl);overflow:hidden;aspect-ratio:4/5}
.about-img-main img,.about-img-accent img{width:100%;height:100%;object-fit:cover}
.about-img-accent{position:absolute;bottom:-20px;right:-16px;width:52%;border-radius:var(--radius-lg);overflow:hidden;box-shadow:0 16px 48px rgba(6,8,13,.45),0 0 0 4px var(--dark);aspect-ratio:1;z-index:2}
.about-years-badge{position:absolute;top:32px;left:-20px;background:var(--primary);border-radius:var(--radius-lg);padding:16px 20px;text-align:center;box-shadow:0 8px 32px rgba(249,115,22,0.4)}
.about-years-badge .num{font-family:var(--font-heading);font-size:48px;font-weight:800;color:var(--white);line-height:1}
.about-years-badge .txt{font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,0.7)}
.check-item{display:flex;gap:14px;align-items:flex-start;margin-bottom:16px}
.check-icon{width:22px;height:22px;background:rgba(249,115,22,0.1);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.check-icon svg{width:12px;height:12px;color:var(--primary)}
.check-item p{font-size:15px;color:var(--gray-4);margin:0}
.testimonials-section{background:var(--dark-2)}
.testimonials-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:768px){.hero{min-height:auto;padding-bottom:40px}.hero .container{max-width:100%}.hero-content{padding:44px 0 80px!important;max-width:100%!important}.hero-meta{width:100%;justify-content:space-between}.hero-meta-item{padding:0 14px}.hero-meta-item:first-child{padding-left:0}.hero-meta-item:last-child{padding-right:0}.advantage-card h3{min-height:0}.about-preview-grid{grid-template-columns:1fr!important;gap:48px!important}.testimonials-grid{grid-template-columns:1fr!important}}
.faq-section{background:var(--dark-2)}
.faq-item{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-lg);padding:24px 28px;margin-bottom:12px;transition:var(--transition)}
.faq-item:hover{border-color:rgba(249,115,22,0.2)}
.faq-item h4{font-size:16px;margin-bottom:8px;color:var(--white)}
.faq-item p{font-size:14px;color:var(--gray-3);line-height:1.7;margin:0}
.faq-grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:640px){.faq-grid-2{grid-template-columns:1fr}}
</style>
<section class="hero">
  <div class="hero-bg" style={`background-image:url('${base}/images/fr-200x/2026-Four-stroke-go-kart8.webp')`}></div><div class="hero-overlay"></div>
  <div class="container"><div class="hero-content">
    <div class="hero-badge"><span>Since 2009</span>Commercial Karting Solutions Manufacturer</div>
    <h1>Built for <em>Speed.</em><br>Engineered to<br>Last.</h1>
    <p class="hero-sub">VortKart® is a factory-direct commercial go kart manufacturer providing rental go karts, racing chassis, and complete turnkey karting solutions for Family Entertainment Centers (FECs), resorts, amusement parks, and track operators worldwide. Custom fleet configurations, competitive factory-direct pricing, and global shipping support.</p>
    <div class="hero-actions">
      <a href={`${base}/contact`} class="btn btn-primary btn-lg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="width:18px;height:18px;vertical-align:-3px;margin-right:8px"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11.5 19.79 19.79 0 010 2.94 2 2 0 012 .76h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>Get a Free Quote</a>
      <a href={`${base}/portfolio`} class="btn btn-outline btn-lg"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="width:18px;height:18px;vertical-align:-3px;margin-right:8px"><rect x="2" y="3" width="20" height="14" rx="2"/><polyline points="8 21 12 17 16 21"/></svg>View Our Projects</a>
    </div>
    <div class="hero-meta">
      <div class="hero-meta-item"><div class="hero-meta-num"><span>500</span>+</div><div class="hero-meta-label">Karts Delivered</div></div>
      <div class="hero-meta-item"><div class="hero-meta-num"><span>60</span>+</div><div class="hero-meta-label">Countries Served</div></div>
      <div class="hero-meta-item"><div class="hero-meta-num"><span>120</span>+</div><div class="hero-meta-label">Tracks Delivered</div></div>
    </div>
  </div></div>
  <div class="scroll-indicator"><div class="scroll-dot"></div><span>Scroll</span></div>
</section>
<div class="trust-bar"><div class="container"><div class="trust-bar-inner">
  <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span><strong>ISO 9001 · CE · SGS</strong> Certified</span></div>
  <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span><strong>48-Hour</strong> Quote Response</span></div>
  <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><span><strong>500+</strong> Fleet Orders Delivered</span></div>
  <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/></svg><span><strong>60+</strong> Countries Served</span></div>
  <div class="trust-item"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg><span><strong>Trusted</strong> by Operators Worldwide</span></div>
</div></div></div>
<section class="section"><div class="container">
  <div class="section-header center fade-in"><div class="label">Why VortKart®</div><h2>Why Operators<br><span class="highlight">Choose Us</span></h2><p>We combine in-house manufacturing, project planning, and long-term technical support to help karting venues reduce downtime, control costs, and launch with confidence.</p></div>
  <div class="grid-3">
    <div class="advantage-card fade-in delay-1"><div class="advantage-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg></div><h3>Factory-Direct Manufacturing</h3><p>As a factory-direct go kart manufacturer, we control frame fabrication, assembly, testing, and quality inspection in-house — delivering consistent quality at competitive factory-direct pricing, with no unnecessary reseller markup.</p></div>
    <div class="advantage-card fade-in delay-2"><div class="advantage-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg></div><h3>Turnkey Export &amp; Project Support</h3><p>From fleet selection and track layout guidance to export documentation, sea/air freight, installation support, and operator training — one accountable supplier from factory floor to your venue.</p></div>
    <div class="advantage-card fade-in delay-3"><div class="advantage-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div><h3>Built for Commercial ROI</h3><p>Our rental go karts are engineered for daily high-volume operation, low-cost maintenance, and fast spare parts supply — maximizing uptime and revenue per venue.</p></div>
  </div>
</div></section>
<div class="stats-strip"><div class="container"><div class="stats-grid">
  <div class="text-center fade-in"><div class="stat-num" data-count="15" data-suffix="+">15+</div><div class="stat-label">Years of Manufacturing</div></div>
  <div class="text-center fade-in delay-1"><div class="stat-num" data-count="48" data-suffix="h">48h</div><div class="stat-label">Quote Turnaround</div></div>
  <div class="text-center fade-in delay-2"><div class="stat-num" data-count="98" data-suffix="%">98%</div><div class="stat-label">Client Retention Rate</div></div>
  <div class="text-center fade-in delay-3"><div class="stat-num" data-count="100" data-suffix="%">100%</div><div class="stat-label">Pre-Shipment QC Tested</div></div>
</div></div></div>
<section class="section services-preview"><div class="container">
  <div class="section-header fade-in"><div class="label">What We Do</div><h2>Complete Karting<br><span class="highlight">Solutions</span></h2><p>From a starter rental fleet to a full-scale attraction — we manufacture, design, and export ready-to-run commercial karting solutions worldwide.</p></div>
  <div class="grid-3">
    <a href={`${base}/portfolio#products`} class="service-preview-card fade-in delay-1"><img src={`${base}/images/fl-270/Recreational-go-karting1.webp`} alt="Commercial go karts" loading="lazy" /><div class="service-preview-overlay"></div><div class="service-preview-content"><span class="service-tag">Products</span><h4>Commercial Go Karts</h4><p>Electric and gas-powered rental karts for indoor and outdoor venues</p></div><div class="service-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg></div></a>
    <a href={`${base}/portfolio#products`} class="service-preview-card fade-in delay-2"><img src={`${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis1.webp`} alt="Racing go kart chassis" loading="lazy" /><div class="service-preview-overlay"></div><div class="service-preview-content"><span class="service-tag">Products</span><h4>Racing Kart Chassis</h4><p>Competition-grade tubular steel racing kart chassis for club and pro racing</p></div><div class="service-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg></div></a>
    <a href={`${base}/portfolio#projects`} class="service-preview-card fade-in delay-3"><img src={`${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis4.webp`} alt="Track design" loading="lazy" /><div class="service-preview-overlay"></div><div class="service-preview-content"><span class="service-tag">Services</span><h4>Track Design &amp; Build</h4><p>Complete attraction planning from concept to grand opening</p></div><div class="service-arrow"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 17L17 7M7 7h10v10"/></svg></div></a>
  </div>
  <div class="text-center mt-32 fade-in"><a href={`${base}/services`} class="btn btn-outline btn-lg">Explore All Services</a></div>
</div></section>
<section class="section testimonials-section"><div class="container">
  <div class="section-header center fade-in"><div class="label">Client Voices</div><h2>What Our <span class="highlight">Operators</span> Say</h2><p>Real feedback from track owners, resort managers, and FEC operators who chose VortKart®.</p></div>
  <div class="testimonials-grid">
    <div class="testimonial-card fade-in delay-1"><div class="testimonial-stars">★★★★★</div><p>"VortKart® designed our entire 800m track from scratch, supplied 30 electric karts, and had us operational in under 6 months. The ROI exceeded our projections in year one."</p><div class="testimonial-author"><div class="author-avatar">JM</div><div><div class="author-name">James Mitchell</div><div class="author-title">Owner, SpeedZone Family Park, USA</div></div></div></div>
    <div class="testimonial-card fade-in delay-2"><div class="testimonial-stars">★★★★★</div><p>"We ordered 20 rental karts for our resort's entertainment hub. The build quality is exceptional — two seasons in and maintenance costs are a fraction of what we budgeted."</p><div class="testimonial-author"><div class="author-avatar">SR</div><div><div class="author-name">Sofia Reyes</div><div class="author-title">GM, Grand Marina Resort, Spain</div></div></div></div>
    <div class="testimonial-card fade-in delay-3"><div class="testimonial-stars">★★★★★</div><p>"As a distributor covering Southeast Asia, VortKart® has been our go-to source for 6 years. Their competitive pricing and consistent quality keeps our clients coming back."</p><div class="testimonial-author"><div class="author-avatar">KT</div><div><div class="author-name">Kevin Tan</div><div class="author-title">Director, AsiaPac Amusements, Singapore</div></div></div></div>
  </div>
</div></section>
<section class="section about-preview"><div class="container"><div class="about-preview-grid">
  <div class="about-img-stack fade-in">
    <div class="about-img-main"><img src={`${base}/images/fl-270/Recreational-go-karting2.webp`} alt="VortKart facility" loading="lazy" /></div>
    <div class="about-img-accent"><img src={`${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis3.webp`} alt="Kart chassis" loading="lazy" /></div>
    <div class="about-years-badge"><div class="num">15</div><div class="txt">Years of<br>Excellence</div></div>
  </div>
  <div class="about-text fade-in delay-2">
    <div class="label">About VortKart®</div>
    <h2>We Don't Just Build<br><span class="highlight">Karts.</span> We Build<br>Businesses.</h2>
    <p style="margin-top:20px">Founded in 2009, VortKart® has grown from a regional kart fabricator to a globally recognized commercial karting solution provider trusted by operators across 60+ countries.</p>
    <ul class="checklist" style="margin:24px 0 32px">
      <li class="check-item"><div class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div><p>Factory-direct pricing with transparent quotes and flexible payment terms</p></li>
      <li class="check-item"><div class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div><p>Full export support — documentation, sea/air freight, and DDP shipping worldwide</p></li>
      <li class="check-item"><div class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div><p>Responsive after-sales service with spare parts shipped to 60+ countries</p></li>
      <li class="check-item"><div class="check-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div><p>OEM/ODM service — custom livery, branding, and fleet configurations</p></li>
    </ul>
    <a href={`${base}/factory`} class="btn btn-primary">Our Full Story</a>
  </div>
</div></div></section>
<section class="section faq-section">
  <div class="container">
    <div class="section-header center fade-in"><div class="label">FAQ</div><h2>Frequently Asked <span class="highlight">Questions</span></h2><p>Common questions about ordering, pricing, and turnkey project support from VortKart®.</p></div>
    <div class="faq-grid-2">
