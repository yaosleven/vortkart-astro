---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const categoryLabels: Record<string, string> = {
  'industry': 'Industry',
  'guide': 'Guide',
  'news': 'News',
  'case-study': 'Case Study',
};

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---
<BaseLayout
  title="VortKart® Blog | Go Kart Industry Insights, Guides & News"
  description="Expert insights on commercial go karting — buyer's guides, track design tips, industry trends, and case studies from VortKart®."
  canonical="https://vortkart.com/blog"
>
<style>
  .blog-hero{background:var(--dark)}
  .blog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:32px}
  .blog-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-xl);overflow:hidden;transition:var(--transition);display:flex;flex-direction:column}
  .blog-card:hover{border-color:rgba(249,115,22,0.3);transform:translateY(-4px)}
  .blog-card-img{aspect-ratio:16/9;overflow:hidden;position:relative}
  .blog-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .blog-card:hover .blog-card-img img{transform:scale(1.05)}
  .blog-card-cat{position:absolute;top:12px;left:12px;background:rgba(6,8,13,.7);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);padding:4px 12px;border-radius:100px;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--primary)}
  .blog-card-body{padding:28px;flex:1;display:flex;flex-direction:column}
  .blog-card-date{font-size:12px;color:var(--gray-3);margin-bottom:10px}
  .blog-card-body h3{font-size:18px;line-height:1.4;margin-bottom:10px}
  .blog-card-body h3 a{transition:color var(--transition)}
  .blog-card-body h3 a:hover{color:var(--primary)}
  .blog-card-excerpt{font-size:14px;color:var(--gray-3);line-height:1.6;flex:1;margin-bottom:16px}
  .blog-card-link{font-size:13px;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--primary);display:inline-flex;align-items:center;gap:6px;transition:gap var(--transition)}
  .blog-card-link:hover{gap:10px}
  .blog-card-link svg{width:14px;height:14px}
  .blog-featured{display:grid;grid-template-columns:1fr 1fr;border-radius:var(--radius-xl);overflow:hidden;border:1px solid rgba(255,255,255,0.08);background:var(--dark-3);margin-bottom:48px;transition:var(--transition)}
  .blog-featured:hover{border-color:rgba(249,115,22,0.35)}
  .blog-featured-img{overflow:hidden}
  .blog-featured-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
  .blog-featured:hover .blog-featured-img img{transform:scale(1.04)}
  .blog-featured-body{padding:48px;display:flex;flex-direction:column;justify-content:center}
  .blog-featured-body .blog-card-cat{position:static;display:inline-block;width:fit-content;margin-bottom:16px}
  .blog-featured-body h3{font-size:26px;line-height:1.3;margin-bottom:12px}
  .blog-featured-body h3 a:hover{color:var(--primary)}
  .blog-featured-body .blog-card-excerpt{font-size:15px;margin-bottom:20px}
  @media(max-width:1024px){.blog-grid{grid-template-columns:1fr 1fr}.blog-featured{grid-template-columns:1fr}}
  @media(max-width:640px){.blog-grid{grid-template-columns:1fr}}
  @media(max-width:768px){.blog-featured-body{padding:28px}.blog-featured{margin-bottom:32px}.blog-card-body{padding:20px}}
  @media(max-width:480px){.blog-featured-body{padding:20px}.blog-featured-body h3{font-size:20px}}
</style>

<section class="page-hero blog-hero">
  <div class="page-hero-bg" style={`background-image:url('${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis4.webp')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="container"><div class="page-hero-content">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href={`${base}/`}>Home</a><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg><span>Blog</span></nav>
    <div class="label">Insights & Guides</div>
    <h1>VortKart® <span class="highlight">Blog</span></h1>
    <p>Expert insights on commercial karting — from buying guides to track design principles.</p>
  </div></div>
</section>

<section class="section" style="background:var(--dark)">
  <div class="container">

    {posts.length > 0 && posts[0].data.featured && (
      <a href={`${base}/blog/${posts[0].id}`} class="blog-featured fade-in">
        <div class="blog-featured-img"><img src={`${base}${posts[0].data.image}`} alt={posts[0].data.title} loading="lazy" /></div>
        <div class="blog-featured-body">
          <span class="blog-card-cat">{categoryLabels[posts[0].data.category]}</span>
          <h3>{posts[0].data.title}</h3>
          <p class="blog-card-excerpt">{posts[0].data.description}</p>
          <span class="blog-card-link">Read Article <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg></span>
        </div>
      </a>
    )}

    <div class="blog-grid">
      {posts.map((post, i) => (
        <article class={`blog-card fade-in ${i === 0 && post.data.featured ? 'delay-1' : i === 1 ? 'delay-1' : i === 2 ? 'delay-2' : ''}`}>
          <div class="blog-card-img">
            <img src={`${base}${post.data.image}`} alt={post.data.title} loading="lazy" />
            <span class="blog-card-cat">{categoryLabels[post.data.category]}</span>
          </div>
          <div class="blog-card-body">
            <span class="blog-card-date">{formatDate(post.data.date)} · {post.data.author}</span>
            <h3><a href={`${base}/blog/${post.id}`}>{post.data.title}</a></h3>
            <p class="blog-card-excerpt">{post.data.description}</p>
            <a href={`${base}/blog/${post.id}`} class="blog-card-link">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
          </div>
        </article>
      ))}
    </div>

    {posts.length === 0 && (
      <div class="section-header center"><p>Blog posts coming soon. Stay tuned!</p></div>
    )}
  </div>
</section>

<section class="cta-section"><div class="container"><div class="fade-in">
  <div class="label" style="justify-content:center">Stay Updated</div>
  <h2>Have a <span class="highlight">Question?</span></h2>
  <p>Our team is ready to help with your karting project — from fleet selection to full track design.</p>
  <div class="cta-buttons"><a href={`${base}/contact`} class="btn btn-primary btn-lg">Get in Touch</a><a href={`${base}/portfolio`} class="btn btn-outline btn-lg">View Portfolio</a></div>
</div></div></section>
</BaseLayout>
