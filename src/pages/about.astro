---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout
  title="About VortKart® | Our Story, Mission & Commercial Go Kart Expertise"
  description="Learn about VortKart® — 15+ years manufacturing commercial go karts and designing karting tracks worldwide. Our mission, values, and competitive advantage."
  canonical="https://vortkart.com/about"
>
<style>
.mission-section{background:var(--dark-2)}
.mission-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.mission-img{border-radius:var(--radius-xl);overflow:hidden;aspect-ratio:4/3}
.mission-img img{width:100%;height:100%;object-fit:cover}
.mission-text h2{margin-bottom:24px}
.mission-text p{margin-bottom:20px}
.mission-quote{border-left:3px solid var(--primary);padding-left:24px;margin:32px 0}
.mission-quote blockquote{font-size:20px;font-style:italic;color:var(--white);line-height:1.6}
.mission-quote cite{font-size:13px;color:var(--gray-3);font-style:normal;display:block;margin-top:12px}
.timeline-section{background:var(--dark)}
.timeline{position:relative;padding-left:32px}
.timeline::before{content:'';position:absolute;left:0;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,var(--primary),rgba(230,57,0,0.1))}
.timeline-item{position:relative;padding:0 0 48px 40px}
.timeline-dot{position:absolute;left:-39px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--primary);border:3px solid var(--dark);box-shadow:0 0 0 3px rgba(230,57,0,0.3)}
.timeline-year{font-family:var(--font-heading);font-size:14px;font-weight:800;color:var(--primary);letter-spacing:.1em;margin-bottom:8px}
.timeline-item h4{font-size:20px;margin-bottom:8px}
.timeline-item p{font-size:15px;max-width:600px}
.values-section{background:var(--dark-2)}
.value-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-lg);padding:32px;text-align:center;transition:var(--transition)}
.value-card:hover{border-color:rgba(230,57,0,0.3);transform:translateY(-4px)}
.value-num{font-family:var(--font-heading);font-size:64px;font-weight:800;color:rgba(230,57,0,0.1);line-height:1;margin-bottom:8px}
.diff-section{background:var(--dark)}
.diff-row{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;margin-bottom:80px;padding-bottom:80px;border-bottom:1px solid rgba(255,255,255,0.06)}
.diff-row.reverse .diff-img{order:2}
.diff-row.reverse .diff-content{order:1}
.diff-row:last-child{border-bottom:none;margin-bottom:0;padding-bottom:0}
.diff-img{border-radius:var(--radius-xl);overflow:hidden;aspect-ratio:16/10}
.diff-img img{width:100%;height:100%;object-fit:cover}
.diff-list{margin-top:20px}
.diff-list li{display:flex;gap:12px;align-items:flex-start;margin-bottom:14px}
.diff-list li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--primary);flex-shrink:0;margin-top:8px}
.diff-list li span{font-size:15px;color:var(--gray-4)}
@media(max-width:1024px){.mission-grid{grid-template-columns:1fr!important;gap:48px!important}.diff-row{grid-template-columns:1fr!important;gap:32px!important}.diff-row.reverse .diff-img{order:1!important}.diff-row.reverse .diff-content{order:2!important}}
</style>

<section class="page-hero">
  <div class="page-hero-bg" style="background-image:url('${base}/images/ev-pro-48/4.jpg')"></div>
  <div class="page-hero-overlay"></div>
  <div class="container"><div class="page-hero-content">
    <nav class="breadcrumb"><a href={`${base}/`}>Home</a><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg><span>About</span></nav>
    <div class="label">Our Story</div>
    <h1>15 Years of <span class="highlight">Karting</span><br>Excellence</h1>
  </div></div>
</section>

<section class="section mission-section">
  <div class="container"><div class="mission-grid">
    <div class="mission-img fade-in"><img src={`${base}/images/ev-pro-48/4.jpg`} alt="VortKart manufacturing team" loading="lazy" /></div>
    <div class="mission-text fade-in delay-2">
      <div class="label">Our Mission</div>
      <h2>Powering the World's<br><span class="highlight">Karting Industry</span></h2>
      <p>VortKart® was founded in 2009 with a clear mission: to make world-class commercial karting accessible to entrepreneurs, resorts, and entertainment venues globally — without the premium markup of traditional distributors.</p>
      <p>We believed that factory-direct manufacturing, combined with deep engineering expertise and end-to-end project support, would create a better solution for operators everywhere. That belief has been validated by 500+ successful deployments across 60+ countries.</p>
      <div class="mission-quote">
        <blockquote>"We don't just sell karts. We invest in our clients' success — from the first consultation through years of ongoing support."</blockquote>
        <cite>— Marcus Chen, Founder &amp; CEO of VortKart®</cite>
      </div>
      <a href={`${base}/contact`} class="btn btn-primary">Work With Us</a>
    </div>
  </div></div>
</section>

<div class="stats-strip">
  <div class="container"><div class="stats-grid">
    <div class="text-center fade-in"><div class="stat-num" data-count="500" data-suffix="+">500+</div><div class="stat-label">Karts in Operation</div></div>
    <div class="text-center fade-in delay-1"><div class="stat-num" data-count="120" data-suffix="+">120+</div><div class="stat-label">Tracks Designed</div></div>
    <div class="text-center fade-in delay-2"><div class="stat-num" data-count="60" data-suffix="+">60+</div><div class="stat-label">Countries Served</div></div>
    <div class="text-center fade-in delay-3"><div class="stat-num" data-count="98" data-suffix="%">98%</div><div class="stat-label">Client Renewal Rate</div></div>
  </div></div>
</div>

<section class="section timeline-section">
  <div class="container">
    <div class="section-header fade-in" style="max-width:600px"><div class="label">Our Journey</div><h2>From Garage to<br><span class="highlight">Global Leader</span></h2></div>
    <div style="max-width:720px"><div class="timeline">
      <div class="timeline-item fade-in"><div class="timeline-dot"></div><div class="timeline-year">2009</div><h4>The Beginning</h4><p>VortKart® founded in a 2,000 sq ft workshop with a team of 6 engineers. First commercial rental kart model launched and adopted by 3 local tracks.</p></div>
      <div class="timeline-item fade-in delay-1"><div class="timeline-dot"></div><div class="timeline-year">2012</div><h4>International Expansion</h4><p>First export orders shipped to Europe and the Middle East. Manufacturing facility expanded to 15,000 sq ft. ISO 9001 quality certification received.</p></div>
      <div class="timeline-item fade-in delay-2"><div class="timeline-dot"></div><div class="timeline-year">2015</div><h4>Track Design Division Launched</h4><p>Expanded services to include full track design, layout consultation, and turnkey project management.</p></div>
      <div class="timeline-item fade-in delay-3"><div class="timeline-dot"></div><div class="timeline-year">2018</div><h4>Electric Kart Series</h4><p>Launched the EV-Pro® electric commercial kart series. Over 200 units shipped in the first year.</p></div>
      <div class="timeline-item fade-in delay-4"><div class="timeline-dot"></div><div class="timeline-year">2024</div><h4>Global Leadership</h4><p>500th kart milestone reached. Operations in 60+ countries. New 40,000 sq ft manufacturing campus opened.</p></div>
    </div></div>
  </div>
</section>

<section class="section diff-section">
  <div class="container">
    <div class="section-header center fade-in"><div class="label">Why We Win</div><h2>Our <span class="highlight">Differentiators</span></h2><p>Three things set VortKart® apart from every other manufacturer in the industry.</p></div>
    <div>
      <div class="diff-row fade-in">
        <div class="diff-img"><img src={`${base}/images/proframe-r32/5.jpg`} alt="Advanced CNC machining" loading="lazy" /></div>
        <div class="diff-content">
          <div class="label">01 — Manufacturing</div>
          <h3>Factory-Direct,<br><span class="highlight">Zero Compromise</span></h3>
          <p>Unlike importers or resellers, VortKart® owns the entire manufacturing chain. Our engineers design every component, our welders fabricate every chassis, and our QA team certifies every unit.</p>
          <ul class="diff-list"><li><span>In-house steel tube bending and CNC machining</span></li><li><span>Proprietary welding jigs for dimensional accuracy</span></li><li><span>100-point pre-shipment quality inspection</span></li><li><span>Custom OEM branding and livery production</span></li></ul>
        </div>
      </div>
      <div class="diff-row reverse fade-in">
        <div class="diff-img"><img src={`${base}/images/proframe-r32/2.jpg`} alt="Track design blueprint" loading="lazy" /></div>
        <div class="diff-content">
          <div class="label">02 — Design Expertise</div>
          <h3>Track Design That<br><span class="highlight">Maximizes Revenue</span></h3>
          <p>Our in-house track designers optimize for throughput, guest experience, and operational efficiency. Every track is modeled in 3D before construction begins.</p>
          <ul class="diff-list"><li><span>3D CAD modeling and simulation for every project</span></li><li><span>Revenue-per-seat-hour optimization analysis</span></li><li><span>FIA-aligned safety barrier and runoff planning</span></li><li><span>Lighting, signage, and spectator zone design</span></li></ul>
        </div>
      </div>
      <div class="diff-row fade-in">
        <div class="diff-img"><img src={`${base}/images/kids-racing/6.jpg`} alt="Customer support" loading="lazy" /></div>
        <div class="diff-content">
          <div class="label">03 — Lifetime Support</div>
          <h3>Support That<br><span class="highlight">Never Stops</span></h3>
          <p>Our relationship with clients doesn't end at delivery. VortKart® operates a global spare parts network and provides dedicated technical support throughout the lifetime of your fleet.</p>
          <ul class="diff-list"><li><span>24/7 technical hotline in multiple languages</span></li><li><span>Spare parts shipped within 48 hours worldwide</span></li><li><span>Annual operator training and recertification programs</span></li><li><span>Fleet upgrade and refurbishment services</span></li></ul>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section values-section">
  <div class="container">
    <div class="section-header center fade-in"><div class="label">What We Stand For</div><h2>Our Core <span class="highlight">Values</span></h2></div>
    <div class="grid-4">
      <div class="value-card fade-in delay-1"><div class="value-num">01</div><h4>Safety First</h4><p>Every kart we manufacture exceeds international safety standards. No shortcuts, ever.</p></div>
      <div class="value-card fade-in delay-2"><div class="value-num">02</div><h4>Quality Over Volume</h4><p>We'd rather build fewer karts perfectly than rush production and compromise durability.</p></div>
      <div class="value-card fade-in delay-3"><div class="value-num">03</div><h4>Client Success</h4><p>Our reputation is built on your profitability. We win only when you win.</p></div>
      <div class="value-card fade-in delay-4"><div class="value-num">04</div><h4>Continuous Innovation</h4><p>We invest 8% of revenue into R&amp;D each year to keep our clients ahead of the market.</p></div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container"><div class="fade-in">
    <div class="label" style="justify-content:center">Let's Build Together</div>
    <h2>Your Vision. Our <span class="highlight">Expertise.</span></h2>
    <p>Whether you're launching a new venue or upgrading an existing fleet, our team is ready to help you succeed.</p>
    <div class="cta-buttons"><a href={`${base}/contact`} class="btn btn-primary btn-lg">Get a Free Quote</a><a href={`${base}/services`} class="btn btn-outline btn-lg">See Our Services</a></div>
  </div></div>
</section>
</BaseLayout>
