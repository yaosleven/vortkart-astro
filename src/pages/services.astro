---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the minimum order quantity?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our standard minimum order is 5 units. Larger fleet orders (20+ units) qualify for volume pricing and priority production slots." }
    },
    {
      "@type": "Question",
      "name": "How long does manufacturing and delivery take?",
      "acceptedAnswer": { "@type": "Answer", "text": "Standard production lead time is 4–8 weeks. We ship worldwide via sea freight (3–6 weeks) or air freight (5–10 days)." }
    },
    {
      "@type": "Question",
      "name": "Do you offer electric and gas-powered options?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. EL-2000 electric for indoor venues, FL-270 gas-powered for outdoor tracks. Both in adult and junior configurations." }
    },
    {
      "@type": "Question",
      "name": "Can you design a track for an indoor space?",
      "acceptedAnswer": { "@type": "Answer", "text": "Absolutely. We specialize in constrained spaces — warehouse conversions, rooftop tracks, basement circuits, and irregular outdoor footprints." }
    },
    {
      "@type": "Question",
      "name": "What warranty and support do you provide?",
      "acceptedAnswer": { "@type": "Answer", "text": "All VortKart® commercial karts carry a 12-month structural warranty on chassis and a 6-month warranty on drivetrain components. We stock spare parts for every kart model we've ever manufactured and can ship globally within 48 hours. Our technical support team is available 24/7 via phone, email, and video call." }
    },
    {
      "@type": "Question",
      "name": "Do you work with distributors and resellers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We actively partner with distributors in territories where we don't have direct representation. Our distributor program offers preferential pricing, co-branded marketing materials, technical training, and dedicated account management." }
    }
  ]
};
---
<BaseLayout
  title="VortKart® Services | Commercial Go Karts, Racing Chassis & Track Design"
  description="VortKart® offers commercial go kart manufacturing, racing kart chassis production, go kart track design and complete turnkey karting solutions for operators worldwide."
  keywords="go kart services, commercial go kart services, go kart track design service, turnkey karting solutions, go kart manufacturer services, go kart supplier, go kart wholesale, go kart fleet management, go kart operator training, go kart turnkey provider"
  canonical="https://vortkart.com/services"
  jsonLd={faqJsonLd}
>
<style>
.service-featured{display:grid;grid-template-columns:1fr 1fr;border-radius:var(--radius-xl);overflow:hidden;border:1px solid rgba(255,255,255,0.08);background:var(--dark-3);margin-bottom:32px;transition:var(--transition)}
.service-featured:hover{border-color:rgba(249,115,22,0.35)}
.service-featured-img{overflow:hidden}
.service-featured-img img{width:100%;height:100%;object-fit:cover;object-position:center 65%;transition:transform .5s ease}
.service-featured:hover .service-featured-img img{transform:scale(1.04)}
.service-featured-body{padding:48px;display:flex;flex-direction:column;justify-content:center}
.process-section{background:var(--dark-2)}
.faq-section{background:var(--dark)}
.faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start}
.pricing-section{background:var(--dark-2)}
.pricing-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.pricing-card{background:var(--dark-3);border:1px solid rgba(255,255,255,0.08);border-radius:var(--radius-xl);padding:40px;text-align:center;transition:var(--transition);position:relative}
.pricing-card.featured{border-color:var(--primary);background:var(--dark-4)}
.pricing-badge{position:absolute;top:-13px;left:50%;transform:translateX(-50%);background:var(--primary);color:var(--white);font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 16px;border-radius:100px}
.pricing-card:hover{transform:translateY(-4px)}
.pricing-tier{font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--primary);margin-bottom:12px}
.pricing-card h3{font-size:28px;margin-bottom:8px}
.pricing-card .price{font-family:var(--font-heading);font-size:48px;font-weight:800;color:var(--white);line-height:1;margin-bottom:4px}
.pricing-card .price-note{font-size:13px;color:var(--gray-3);margin-bottom:24px}
.pricing-divider{height:1px;background:rgba(255,255,255,0.06);margin:24px 0}
.pricing-features{text-align:left}
.pricing-features li{display:flex;gap:10px;align-items:center;padding:8px 0;font-size:14px;color:var(--gray-4)}
.pricing-features li svg{width:16px;height:16px;color:var(--primary);flex-shrink:0}
.service-card{background:var(--dark-3);border-radius:var(--radius-xl);border:1px solid rgba(255,255,255,0.08);overflow:hidden;transition:var(--transition)}
.service-card:hover{border-color:rgba(249,115,22,0.35);transform:translateY(-6px)}
.service-card-img{aspect-ratio:16/9;overflow:hidden}
.service-card-img img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.service-card:hover .service-card-img img{transform:scale(1.05)}
.service-card-body{padding:36px}
.service-card-icon{width:52px;height:52px;background:rgba(249,115,22,0.1);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;margin-bottom:20px}
.service-card-icon svg{width:26px;height:26px;color:var(--primary)}
.service-features{list-style:none;margin:0}
.service-features li{display:flex;gap:10px;align-items:center;padding:8px 0;border-bottom:1px solid rgba(255,255,255,0.05);font-size:14px;color:var(--gray-4)}
.service-features li:last-child{border-bottom:none}
.service-features li::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--primary);flex-shrink:0}
.service-card-link{display:inline-flex;align-items:center;gap:8px;margin-top:24px;font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--primary);transition:gap var(--transition)}
.service-card-link:hover{gap:12px}
.service-card-link svg{width:16px;height:16px}
@media(max-width:1024px){.service-featured{grid-template-columns:1fr!important}.faq-grid{grid-template-columns:1fr!important;gap:48px}.pricing-cards{grid-template-columns:1fr!important}}
</style>
<section class="page-hero">
  <div class="page-hero-bg" style={`background-image:url('${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis1.webp')`}></div>
  <div class="page-hero-overlay"></div>
  <div class="container"><div class="page-hero-content">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href={`${base}/`}>Home</a><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="9 18 15 12 9 6"/></svg><span>Services</span></nav>
    <div class="label">What We Offer</div>
    <h1>Full-Spectrum<br><span class="highlight">Karting</span> Solutions</h1>
  </div></div>
</section>
<section class="section" id="commercial"><div class="container">
  <div class="section-header center fade-in"><div class="label">Our Services</div><h2>Everything You Need<br>to <span class="highlight">Launch &amp; Operate</span></h2><p>From a single kart purchase to a complete attraction — as a commercial go kart manufacturer and turnkey supplier, we cover every stage.</p></div>
  <div class="service-featured fade-in">
    <div class="service-featured-img"><img src={`${base}/images/fl-270/Recreational-go-karting1.webp`} alt="Fleet of commercial go karts" loading="lazy" /></div>
    <div class="service-featured-body">
      <div class="label">Most Popular</div><h3>Commercial <span class="highlight">Go Karts</span></h3>
      <p style="margin:16px 0 24px">Purpose-built for high-throughput rental operations, our commercial go karts deliver unmatched durability, consistent performance, and minimal maintenance demands. As a factory-direct go kart manufacturer and wholesale supplier, we protect your bottom line race after race.</p>
      <ul class="service-features"><li>EL-2000 electric series — zero emissions, low noise, ideal for indoor/outdoor</li><li>FL-270 gas-powered series — Honda GX270 engine, max power for outdoor tracks</li><li>Junior Kart series — purpose-designed for 5–12 year age groups</li><li>Custom fleet sizing from 5 to 100+ units</li><li>Fleet management &amp; timing system integration</li></ul>
      <a href={`${base}/contact`} class="service-card-link">Request Fleet Quote <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg></a>
    </div>
  </div>
  <div class="grid-3" style="margin-top:32px">
    <div class="service-card fade-in delay-1" id="racing"><div class="service-card-img"><img src={`${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis1.webp`} alt="Racing kart chassis" loading="lazy" /></div><div class="service-card-body"><div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div><h3>Racing Kart Chassis</h3><p>Competition-grade tubular steel chassis for club and professional racing.</p><ul class="service-features"><li>CIK/FIA homologated designs</li><li>32mm &amp; 30mm tube options</li><li>Junior, Cadet, and Senior sizes</li><li>Custom OEM branding available</li></ul><a href={`${base}/contact`} class="service-card-link">Get Chassis Quote <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg></a></div></div>
    <div class="service-card fade-in delay-2" id="track"><div class="service-card-img"><img src={`${base}/images/kz-class-chassis/KZ-Class-Kart-Chassis4.webp`} alt="Track design" loading="lazy" /></div><div class="service-card-body"><div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div><h3>Track Design</h3><p>Custom go kart track layout design for any space — indoor, outdoor, rooftop, or integrated in a larger attraction.</p><ul class="service-features"><li>3D CAD design and rendering</li><li>Feasibility study and site analysis</li><li>Safety barrier specification</li><li>Revenue optimization layout modeling</li></ul><a href={`${base}/contact`} class="service-card-link">Request Track Design <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg></a></div></div>
    <div class="service-card fade-in delay-3" id="turnkey"><div class="service-card-img"><img src={`${base}/images/fr-200x/2026-Four-stroke-go-kart8.webp`} alt="Turnkey karting" loading="lazy" /></div><div class="service-card-body"><div class="service-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 010 14.14M4.93 4.93a10 10 0 000 14.14"/></svg></div><h3>Turnkey Solutions</h3><p>The complete package: track design, kart supply, timing systems, staff training, and grand opening. One partner.</p><ul class="service-features"><li>Single point of contact management</li><li>Barrier, signage &amp; pit lane setup</li><li>Timing &amp; fleet management systems</li><li>Staff training and operations manual</li></ul><a href={`${base}/contact`} class="service-card-link">Get Turnkey Proposal <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg></a></div></div>
  </div>
</div></section>
<section class="section process-section"><div class="container">
  <div class="section-header center fade-in"><div class="label">How It Works</div><h2>From Enquiry to<br><span class="highlight">Opening Day</span></h2><p>Our proven 4-step process ensures every go kart project — from fleet orders to turnkey track builds — is delivered on time, on spec, and ready to generate revenue.</p></div>
  <div class="process-steps fade-in">
    <div class="process-step"><div class="step-num">01</div><h4>Discovery Call</h4><p>Tell us your vision, site dimensions, budget, and timeline. We'll match you to the right solution within 48 hours.</p></div>
    <div class="process-step"><div class="step-num">02</div><h4>Design &amp; Proposal</h4><p>Our engineers produce a custom track layout, kart specification, and detailed project proposal with full cost breakdown.</p></div>
    <div class="process-step"><div class="step-num">03</div><h4>Manufacturing &amp; Shipping</h4><p>Your karts are manufactured to spec, QA-inspected, and shipped with all documentation for smooth customs clearance.</p></div>
    <div class="process-step"><div class="step-num">04</div><h4>Installation &amp; Launch</h4><p>Our team commissions the track, sets up all systems, trains your staff, and hands over a fully operational attraction.</p></div>
  </div>
</div></section>
<section class="section faq-section"><div class="container"><div class="faq-grid">
  <div class="faq-left fade-in"><div class="label">FAQs</div><h2>Common<br><span class="highlight">Questions</span></h2><p>Everything you need to know before starting your karting project.</p><a href={`${base}/contact`} class="btn btn-primary" style="margin-top:8px">Ask a Question</a></div>
  <div class="faq-right fade-in delay-2">
    <div class="faq-item"><button class="faq-question" aria-expanded="false">What is the minimum order quantity?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button><div class="faq-answer"><div class="faq-answer-inner">Our standard minimum order is 5 units. Larger fleet orders (20+ units) qualify for volume pricing and priority production slots.</div></div></div>
    <div class="faq-item"><button class="faq-question" aria-expanded="false">How long does manufacturing and delivery take?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button><div class="faq-answer"><div class="faq-answer-inner">Standard production lead time is 4–8 weeks. We ship worldwide via sea freight (3–6 weeks) or air freight (5–10 days).</div></div></div>
    <div class="faq-item"><button class="faq-question" aria-expanded="false">Do you offer electric and gas-powered options?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button><div class="faq-answer"><div class="faq-answer-inner">Yes. EL-2000 electric for indoor venues, FL-270 gas-powered for outdoor tracks. Both in adult and junior configurations.</div></div></div>
    <div class="faq-item"><button class="faq-question" aria-expanded="false">Can you design a track for an indoor space?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button><div class="faq-answer"><div class="faq-answer-inner">Absolutely. We specialize in constrained spaces — warehouse conversions, rooftop tracks, basement circuits, and irregular outdoor footprints.</div></div></div>
    <div class="faq-item"><button class="faq-question" aria-expanded="false">What warranty and support do you provide?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button><div class="faq-answer"><div class="faq-answer-inner">All VortKart® commercial karts carry a 12-month structural warranty on chassis and a 6-month warranty on drivetrain components. We stock spare parts for every kart model we've ever manufactured and can ship globally within 48 hours. Our technical support team is available 24/7 via phone, email, and video call.</div></div></div>
    <div class="faq-item"><button class="faq-question" aria-expanded="false">Do you work with distributors and resellers?<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button><div class="faq-answer"><div class="faq-answer-inner">Yes. We actively partner with distributors in territories where we don't have direct representation. Our distributor program offers preferential pricing, co-branded marketing materials, technical training, and dedicated account management. Contact us to enquire about territory availability in your region.</div></div></div>
  </div>
</div></div></section>
<section class="section pricing-section"><div class="container">
  <div class="section-header center fade-in"><div class="label">Investment Tiers</div><h2>Find the Right<br><span class="highlight">Starting Point</span></h2><p>Solutions scaled to your ambition.</p></div>
  <div class="pricing-cards">
    <div class="pricing-card fade-in delay-1"><div class="pricing-tier">Starter</div><h3>Fleet Package</h3><div class="price">5–10</div><div class="price-note">Karts — Custom pricing by spec</div><div class="pricing-divider"></div><ul class="pricing-features"><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>5–10 commercial karts</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Standard livery</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>12-month warranty</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Operator manual</li></ul><a href={`${base}/contact`} class="btn btn-outline" style="width:100%;justify-content:center;margin-top:28px">Get Quote</a></div>
    <div class="pricing-card featured fade-in delay-2"><div class="pricing-badge">Most Popular</div><div class="pricing-tier">Growth</div><h3>Track + Fleet</h3><div class="price">20+</div><div class="price-note">Karts + Track Design bundle</div><div class="pricing-divider"></div><ul class="pricing-features"><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>20+ commercial karts</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Custom track design included</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Timing system integration</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Staff training program</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Priority technical support</li></ul><a href={`${base}/contact`} class="btn btn-primary" style="width:100%;justify-content:center;margin-top:28px">Get Quote</a></div>
    <div class="pricing-card fade-in delay-3"><div class="pricing-tier">Enterprise</div><h3>Turnkey Attraction</h3><div class="price">50+</div><div class="price-note">Karts — Complete build-out</div><div class="pricing-divider"></div><ul class="pricing-features"><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>50+ kart fleet</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Full track construction oversight</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Branded livery &amp; signage</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Dedicated project manager</li><li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Grand opening support</li></ul><a href={`${base}/contact`} class="btn btn-outline" style="width:100%;justify-content:center;margin-top:28px">Get Quote</a></div>
  </div>
</div></section>
<section class="cta-section"><div class="container"><div class="fade-in">
  <div class="label" style="justify-content:center">Start Today</div>
  <h2>Ready to Discuss<br><span class="highlight">Your Project?</span></h2>
  <p>Our team responds to every enquiry within 24 hours with a tailored recommendation.</p>
  <div class="cta-buttons"><a href={`${base}/contact`} class="btn btn-primary btn-lg">Request a Quote</a><a href={`${base}/portfolio`} class="btn btn-outline btn-lg">View Our Work</a></div>
</div></div></section>
</BaseLayout>
